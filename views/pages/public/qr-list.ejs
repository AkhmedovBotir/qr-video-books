<!DOCTYPE html>
<html lang="uz">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body class="min-h-screen bg-slate-950 text-slate-100">
    <main class="mx-auto w-full max-w-6xl px-4 py-8">
      <section class="space-y-6">
        <div class="rounded-2xl border border-slate-800 bg-slate-900 p-5">
          <h1 class="text-2xl font-bold">Ommaviy QR sahifa</h1>
          <p class="mt-1 text-sm text-slate-400">Bu sahifa barcha foydalanuvchilar uchun ochiq.</p>
        </div>

        <% if (!items.length) { %>
          <div class="rounded-xl border border-slate-800 bg-slate-900 p-6 text-slate-300">
            Hozircha QR yozuvlari mavjud emas.
          </div>
        <% } %>

        <div class="grid gap-4 md:grid-cols-2">
          <% items.forEach((item) => { %>
            <article class="rounded-2xl border border-slate-800 bg-slate-900 p-4">
              <div class="grid gap-4 sm:grid-cols-[120px_1fr] sm:items-center">
                <img src="<%= item.qrImage %>" alt="QR kod" class="h-28 w-28 rounded-lg bg-white p-1" />
                <div>
                  <h3 class="text-lg font-semibold"><%= item.name %></h3>
                  <p class="mt-1 text-xs text-slate-400"><%= item.file.originalName %></p>
                  <button
                    type="button"
                    data-modal-open="publicViewModal-<%= item._id %>"
                    class="mt-3 rounded-lg bg-emerald-600 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-500"
                  >
                    Ko'rish
                  </button>
                </div>
              </div>
            </article>
          <% }) %>
        </div>

        <% items.forEach((item) => { %>
          <div id="publicViewModal-<%= item._id %>" class="fixed inset-0 z-50 hidden overflow-y-auto bg-black/70 p-3 md:p-4">
            <div class="mx-auto my-4 w-full max-w-6xl rounded-2xl border border-slate-700 bg-slate-900 p-4 md:p-5">
              <div class="mb-4 flex items-center justify-between">
                <h3 class="text-lg font-semibold md:text-xl">QR ko'rish: <%= item.name %></h3>
                <button type="button" data-modal-close="publicViewModal-<%= item._id %>" class="rounded bg-slate-800 px-2 py-1">X</button>
              </div>

              <div class="grid gap-4 md:grid-cols-2">
                <div class="rounded-xl border border-slate-800 bg-black p-2">
                  <% if ((item.file.mimeType || "").startsWith("video/")) { %>
                    <video
                      class="h-[34vh] w-full rounded-lg object-contain sm:h-[42vh] md:h-[50vh]"
                      autoplay
                      controls
                      playsinline
                      preload="metadata"
                      controlsList="nodownload noplaybackrate"
                    >
                      <source src="/q/<%= item.qrToken %>/stream" type="<%= item.file.mimeType %>" />
                    </video>
                  <% } else { %>
                    <div class="flex h-[34vh] items-center justify-center rounded-lg border border-slate-700 bg-slate-950 text-slate-300 sm:h-[42vh] md:h-[50vh]">
                      Bu fayl turi video emas.
                    </div>
                  <% } %>
                </div>

                <div class="space-y-4 rounded-xl border border-slate-800 bg-slate-950 p-4">
                  <div>
                    <p class="text-xs uppercase tracking-wide text-slate-400">Nomi</p>
                    <p class="text-lg font-semibold"><%= item.name %></p>
                  </div>
                  <div>
                    <p class="text-xs uppercase tracking-wide text-slate-400">Fayl</p>
                    <p class="text-sm text-slate-300"><%= item.file.originalName %></p>
                  </div>
                  <div>
                    <p class="text-xs uppercase tracking-wide text-slate-400">Tur</p>
                    <p class="text-sm text-slate-300"><%= item.file.mimeType %></p>
                  </div>
                  <div>
                    <p class="mb-2 text-xs uppercase tracking-wide text-slate-400">QR</p>
                    <img src="<%= item.qrImage %>" alt="QR kod" class="h-36 w-36 rounded-lg bg-white p-1" />
                    <a
                      href="<%= item.qrImage %>"
                      download="qr-<%= item.name.replace(/[^a-zA-Z0-9_-]/g, '-') %>.png"
                      class="mt-3 inline-block rounded-lg bg-sky-600 px-4 py-2 text-sm font-medium text-white hover:bg-sky-500"
                    >
                      QR rasmni yuklab olish
                    </a>
                  </div>
                  <a href="<%= item.qrLink %>" target="_blank" class="inline-block rounded-lg bg-emerald-600 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-500">
                    Alohida oynada ochish
                  </a>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      </section>
    </main>

    <script>
      (() => {
        const openButtons = document.querySelectorAll("[data-modal-open]");
        const closeButtons = document.querySelectorAll("[data-modal-close]");

        const openModal = (id) => {
          const modal = document.getElementById(id);
          if (!modal) return;
          modal.classList.remove("hidden");
          document.body.classList.add("overflow-hidden");
        };

        const closeModal = (id) => {
          const modal = document.getElementById(id);
          if (!modal) return;
          modal.classList.add("hidden");
          if (!document.querySelector('[id^="publicViewModal-"]:not(.hidden)')) {
            document.body.classList.remove("overflow-hidden");
          }
        };

        openButtons.forEach((button) => {
          button.addEventListener("click", () => openModal(button.dataset.modalOpen));
        });

        closeButtons.forEach((button) => {
          button.addEventListener("click", () => closeModal(button.dataset.modalClose));
        });
      })();
    </script>
  </body>
</html>
