<section class="mx-auto w-full max-w-md">
  <div class="rounded-2xl border border-slate-800 bg-slate-900 p-6 shadow-lg">
    <h2 class="text-2xl font-bold">Admin kirish</h2>
    <p class="mt-1 text-sm text-slate-400">Foydalanuvchi nomi va parol bilan tizimga kiring.</p>

    <% if (errorMessage) { %>
      <div class="mt-4 rounded-lg border border-rose-700 bg-rose-900/40 px-3 py-2 text-sm text-rose-200">
        <%= errorMessage %>
      </div>
    <% } %>

    <form action="/admin/login" method="POST" class="mt-6 space-y-4">
      <div>
        <label for="username" class="mb-1 block text-sm font-medium text-slate-200">Foydalanuvchi nomi</label>
        <input
          id="username"
          name="username"
          value="<%= formData.username %>"
          placeholder="admin"
          required
          class="w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 outline-none ring-emerald-500 focus:ring"
        />
      </div>

      <div>
        <label for="password" class="mb-1 block text-sm font-medium text-slate-200">Parol</label>
        <input
          id="password"
          type="password"
          name="password"
          placeholder="********"
          required
          class="w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 outline-none ring-emerald-500 focus:ring"
        />
      </div>

      <button
        type="submit"
        class="w-full rounded-lg bg-emerald-600 px-4 py-2 font-semibold text-white transition hover:bg-emerald-500"
      >
        Kirish
      </button>
    </form>
  </div>
</section>
