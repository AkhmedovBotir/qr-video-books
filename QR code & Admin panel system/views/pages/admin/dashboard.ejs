<section class="space-y-6">
  <div class="rounded-2xl border border-emerald-700/40 bg-emerald-900/20 p-6">
    <p class="text-sm uppercase tracking-wider text-emerald-300">Admin panel</p>
    <h2 class="mt-2 text-3xl font-bold">Xush kelibsiz, <%= currentAdmin?.name || "Admin" %></h2>
    <p class="mt-3 text-slate-300">
      Bu boshqaruv sahifasi mobil, planshet va kompyuter qurilmalarda moslashuvchan ishlaydi.
    </p>
  </div>

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    <article class="rounded-xl border border-slate-800 bg-slate-900 p-4">
      <p class="text-sm text-slate-400">Jami QR</p>
      <p class="mt-2 text-2xl font-bold"><%= qrCount %></p>
    </article>
    <article class="rounded-xl border border-slate-800 bg-slate-900 p-4">
      <p class="text-sm text-slate-400">Admin</p>
      <p class="mt-2 text-2xl font-bold"><%= currentAdmin?.username %></p>
    </article>
    <article class="rounded-xl border border-slate-800 bg-slate-900 p-4">
      <p class="text-sm text-slate-400">Asosiy bo'lim</p>
      <p class="mt-2 text-2xl font-bold">QR boshqaruvi</p>
    </article>
    <article class="rounded-xl border border-slate-800 bg-slate-900 p-4">
      <p class="text-sm text-slate-400">Holat</p>
      <p class="mt-2 text-2xl font-bold text-emerald-300">Aktiv</p>
    </article>
  </div>

  <div class="grid gap-4 lg:grid-cols-3">
    <article class="rounded-xl border border-slate-800 bg-slate-900 p-5 lg:col-span-2">
      <h3 class="text-lg font-semibold">Tezkor amallar</h3>
      <div class="mt-4 grid gap-3 sm:grid-cols-2">
        <a href="/admin/qr?modal=create" class="rounded-lg bg-slate-800 px-4 py-2 text-left hover:bg-slate-700">Yangi QR yaratish</a>
        <a href="/admin/qr" class="rounded-lg bg-slate-800 px-4 py-2 text-left hover:bg-slate-700">QR ro'yxatini ochish</a>
        <a href="/admin/analytics" class="rounded-lg bg-slate-800 px-4 py-2 text-left hover:bg-slate-700">Analitikani ochish</a>
      </div>
    </article>

    <article class="rounded-xl border border-slate-800 bg-slate-900 p-5">
      <h3 class="text-lg font-semibold">Admin ma'lumoti</h3>
      <ul class="mt-3 space-y-2 text-sm text-slate-300">
        <li><span class="text-slate-400">Ism:</span> <%= currentAdmin?.name %></li>
        <li><span class="text-slate-400">Telefon:</span> <%= currentAdmin?.phone %></li>
        <li><span class="text-slate-400">Username:</span> <%= currentAdmin?.username %></li>
      </ul>
    </article>
  </div>
</section>
